# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf
*.pxi text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Batch
*.bat text eol=crlf
*.cmd text eol=crlf

# Text
*.txt text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary
*.pkl binary
*.pickle binary
*.pyc binary
*.pyo binary
*.pyd binary
